---
import Base from "../layouts/Base.astro";
---

<Base title="Delete your account — Pickup">
  <h1>Delete your account</h1>
  <p>You can delete your Pickup account and all associated data at any time:</p>
  <ol>
    <li><strong>In the app:</strong> Profile → Settings → Delete Account.</li>
    <li>
      <strong>By email:</strong> send a deletion request from your account email to
      <a href="mailto:support@pickupsports.app">support@pickupsports.app</a>.
      We process requests within 30 days.
    </li>
  </ol>
  <p>
    Deletion removes your profile, photos, events, RSVPs, check-in history, and chat
    identity. Some records may be retained where required by law (e.g. moderation
    reports).
  </p>
</Base>
